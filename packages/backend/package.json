{
  "name": "@hospital-orchestrator/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend service for Hospital Workflow Orchestrator",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node-dev --transpile-only src/db/migrate.ts",
    "db:seed": "ts-node-dev --transpile-only src/db/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.50.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.1",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
